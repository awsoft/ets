        }
      }
    },
    {
      "id": "paypal-transaction",
      "name": "PayPal Transaction Receipt",
      "priority": 110,
      "type": "billing",
      "detect": {
        "sender_domain": "paypal.com",
        "subject_regex": "(?i)(receipt|payment|sent|received|charged|you paid|you received)"
      },
      "extract": {
        "amount": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "direction": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)you sent|you paid|payment sent": "sent",
            "(?i)you received|payment received|money received": "received",
            "(?i)you were charged|charged to": "charged"
          }
        },
        "counterparty": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:to|from|with)\\s+([A-Za-z0-9 ]{2,40}?)(?:\\s+for|\\s+on|\\.|$)"
        }
      }
    },
    {
      "id": "amazon-order",
      "name": "Amazon Order Confirmation",
      "priority": 105,
      "type": "order_confirm",
      "detect": {
        "sender_domain": "amazon.com",
        "subject_regex": "(?i)(order (confirmed|received|placed))"
      },
      "extract": {
        "order_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?i)#([A-Z0-9\\-]{10,})"
        },
        "total": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "item_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "walmart-order",
      "name": "Walmart Order Confirmation",
      "priority": 105,
      "type": "order_confirm",
      "detect": {
        "sender_domain": "walmart.com",
        "subject_regex": "(?i)(order (confirmed|received|placed)|thank you for your order|your receipt)"
      },
      "extract": {
