          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|estimated|delivery date)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        },
        "carrier": {
          "static": "DHL"
        }
