      },
      "tags": {"travel": 0.3, "marketing": 0.0, "action_required": 0.0, "newsletter": 0.0},
      "extract": {
        "tracking_number": {
          "source": ["subject", "snippet"],
          "regex": "\\b(\\d{10,11}|[A-Z]{3}\\d{7,})\\b"
        },
        "status": {
          "source": ["subject", "snippet"],
          "enum_map": {
            "(?i)out.?for.?delivery|with courier": "out_for_delivery",
