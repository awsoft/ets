          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:order|#)\\s*([0-9\\-]{6,})"
        },
        "total": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "item_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "ebay-order",
      "name": "eBay Order Confirmation",
      "priority": 105,
      "type": "order_confirm",
      "detect": {
        "sender_domain": "ebay.com",
        "subject_regex": "(?i)(order|purchase|won|you bought)"
      },
      "extract": {
        "order_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:order|item)\\s*#?(\\d{10,})"
        },
        "total": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "seller": {
          "source": "snippet",
          "regex": "(?:from|seller:)\\s+([^\\n,]{2,40})"
        },
        "item_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "stripe-receipt",
      "name": "Stripe Payment Receipt",
      "priority": 100,
      "type": "billing",
      "detect": {
        "sender_contains": "stripe.com"
      },
      "extract": {
        "amount": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "merchant": {
          "source": "from_name",
          "max_chars": 40
        },
        "date": {
          "source": "snippet",
          "regex": "\\b(\\d{1,2}/\\d{1,2}/\\d{2,4}|[A-Za-z]+ \\d+,?\\s*\\d{4}|\\d{4}-\\d{2}-\\d{2})\\b"
        }
      }
    },
    {
      "id": "github-notification",
      "name": "GitHub Notification",
      "priority": 100,
      "type": "unclassified",
      "detect": {
        "sender_domain": "github.com",
        "subject_regex": "(?i)(pull request|issue|review|mention|assigned)"
      },
      "extract": {
        "repo": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "([a-zA-Z0-9_\\-]+/[a-zA-Z0-9_\\-]+)"
        },
        "action": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)mentioned you|@mention": "mentioned",
            "(?i)assigned to you|you were assigned": "assigned",
            "(?i)review requested|requested your review": "review_requested",
            "(?i)commented on|left a comment": "commented",
            "(?i)\\bopened\\b": "opened",
            "(?i)\\bclosed\\b": "closed",
            "(?i)\\bmerged\\b": "merged"
          }
        },
        "pr_or_issue_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "#(\\d+)"
        }
      }
    },
    {
      "id": "calendar-invite",
      "name": "Calendar Invite",
      "priority": 95,
      "type": "calendar_invite",
      "detect": {
        "subject_regex": "(?i)(invited you to|invitation:|calendar invite|you.re invited|save the date)"
      },
      "extract": {
        "event_name": {
          "source": "subject",
          "regex": "(?:invitation:|invited you to|you.re invited to|save the date:?)\\s*(.+)"
        },
        "date_hint": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:on|for|at)\\s+([A-Za-z]+ \\d+,?\\s*\\d{4}|(?:Mon|Tue|Wed|Thu|Fri|Sat|Sun)\\w*,?\\s*[A-Za-z]+ \\d+)"
        },
        "time_hint": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\b(\\d{1,2}:\\d{2}\\s*(?:AM|PM|am|pm))\\b"
        },
        "location_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "generic-financial-alert",
      "name": "Financial / Security Alert",
      "priority": 90,
      "type": "financial_alert",
      "detect": {
        "subject_regex": "(?i)(fraud (alert|detected)|unusual (activity|sign.in|login)|account (locked|suspended|compromised|disabled|restricted)|security (alert|notice|warning)|payment (failed|declined)|suspicious (activity|transaction|login)|unauthorized)"
      },
      "extract": {
        "alert_type": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)fraud|fraudulent|suspicious.(?:activity|charge|transaction)": "fraud",
            "(?i)account.(?:locked|suspended|disabled|compromised)": "account_locked",
            "(?i)payment.(?:failed|declined)|declined.payment": "payment_failed",
            "(?i)unusual.activity|unusual.sign.in|unrecognized": "unusual_activity",
            "(?i)security.(?:alert|notice|warning)|verify.your|unauthorized": "security_alert"
          }
        },
        "account_hint": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:account|card|ending in)\\s*[*x]*(\\d{4})\\b"
        },
        "amount": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "urgent": {
          "static": true
        }
      }
    },
    {
      "id": "generic-subscription-expiry",
      "name": "Subscription Expiry / Renewal",
      "priority": 80,
      "type": "subscription",
      "detect": {
        "subject_regex": "(?i)(subscription (expiring|expires|will (renew|expire|end)|ending)|your (trial|subscription|membership) (ends|expires|is expiring) (soon|in \\d+|tomorrow|today)|upcoming (renewal|charge|payment))"
      },
      "extract": {
        "service": {
          "source": "from_name",
          "max_chars": 40
        },
        "expiry_date": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:expires?|ends?|renews?|renewal date)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\d{1,2}/\\d{1,2}/\\d{2,4})"
        },
        "amount": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "action_needed": {
          "static": true
        }
      }
    },
    {
      "id": "generic-job",
      "name": "Job / Recruiting Email",
      "priority": 75,
      "type": "job",
      "detect": {
        "subject_regex": "(?i)(offer letter|interview (invitation|request|scheduled|confirmed)|we.d like to (speak|connect|discuss|interview)|application (moved forward|status update|decision|next steps)|recruiter (outreach|message)|exciting (opportunity|role|position))"
      },
      "extract": {
        "company": {
          "source": "from_name",
          "max_chars": 40
        },
        "action": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)offer letter|we.re (?:pleased|excited|happy|delighted) to offer": "offer",
            "(?i)\\binterview\\b|schedule a call|speak with you|connect with you": "interview",
            "(?i)application (?:update|status|received|moved|decision|next steps)": "application_update",
            "(?i)recruiter|outreach|exploring|opportunity": "recruiter_outreach"
          }
        },
        "role": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:for the|for a|as a|as an|the|a)\\s+([A-Z][a-zA-Z &]+?)(?:\\s+(?:position|role|opportunity|at|with|@)|[,.]|$)"
        },
        "action_summary": {
          "source": "subject",
          "max_chars": 80
        }
      }
    },
