        "status": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)out.?for.?delivery|out for post": "out_for_delivery",
            "(?i)\\bdelivered\\b|delivery complete": "delivered",
            "(?i)available for pickup|pickup": "pickup_ready",
            "(?i)in transit|shipped|accepted": "shipped"
          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|expected delivery|arriving)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        },
        "carrier": {
          "static": "USPS"
        }
      }
    },
