        }
      }
    },
    {
      "id": "generic-billing",
      "name": "Generic Billing / Invoice",
      "priority": 60,
      "type": "billing",
      "detect": {
        "subject_regex": "(?i)(bill|invoice|statement|payment due|amount due|balance due|your (bill|invoice|statement) is ready|new statement)"
      },
      "extract": {
        "amount": {
          "source": [
