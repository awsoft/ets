      },
      "tags": {"marketing": 0.1, "financial": 0.3, "action_required": 0.0},
      "extract": {
        "order_number": {
          "source": ["subject", "snippet"],
          "regex": "(?:order|item)\\s*#?(\\d{10,})"
        },
        "total": {
          "source": ["subject", "snippet"],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "seller": {
          "source": "snippet",
          "regex": "(?:from|seller:)\\s+([^\\n,]{2,40})"
        },
        "item_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "stripe-receipt",
      "name": "Stripe Payment Receipt",
      "priority": 100,
      "type": "billing",
      "detect": {
        "sender_contains": "stripe.com"
      },
      "tags": {"financial": 0.9, "action_required": 0.4},
      "extract": {
