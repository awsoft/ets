        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|arriving|estimated)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        }
      }
    },
    {
      "id": "ebay-shipping",
      "name": "eBay Shipping Update",
      "priority": 110,
      "type": "shipping",
      "detect": {
        "sender_domain": "ebay.com",
        "subject_regex": "(?i)(shipped|out for delivery|delivered)"
      },
      "tags": {"travel": 0.3, "marketing": 0.0, "action_required": 0.0, "newsletter": 0.0},
      "extract": {
        "tracking_number": {
          "source": ["subject", "snippet"],
          "regex": "(?:tracking[:\\s#]+|1Z)([A-Z0-9]{10,})"
        },
        "carrier": {
          "source": ["sender", "snippet"],
          "enum_map": {
            "(?i)ups\\.com|\\bUPS\\b|united.?parcel": "UPS",
            "(?i)fedex\\.com|\\bFedEx\\b|federal.?express": "FedEx",
            "(?i)usps\\.com|\\bUSPS\\b|postal.?service": "USPS",
            "(?i)dhl\\.com|\\bDHL\\b": "DHL"
          }
        },
        "status": {
          "source": ["subject", "snippet"],
          "enum_map": {
            "(?i)out.?for.?delivery|on its way": "out_for_delivery",
            "(?i)\\bdelivered\\b|delivery complete": "delivered",
            "(?i)\\bshipped\\b|in transit": "shipped"
          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|arriving|estimated)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        }
      }
    },
    {
      "id": "paypal-transaction",
      "name": "PayPal Transaction Receipt",
      "priority": 110,
      "type": "billing",
      "detect": {
        "sender_domain": "paypal.com",
        "subject_regex": "(?i)(receipt|payment|sent|received|charged|you paid|you received)"
      },
      "tags": {"financial": 0.9, "action_required": 0.4},
      "extract": {
        "amount": {
          "source": ["subject", "snippet"],
          "regex": "\\$[\\d,]+\\.?\\d*"
        },
        "direction": {
          "source": ["subject", "snippet"],
          "enum_map": {
            "(?i)you sent|you paid|payment sent": "sent",
            "(?i)you received|payment received|money received": "received",
            "(?i)you were charged|charged to": "charged"
          }
        },
        "counterparty": {
          "source": ["subject", "snippet"],
          "regex": "(?:to|from|with)\\s+([A-Za-z0-9 ]{2,40}?)(?:\\s+for|\\s+on|\\.|$)"
        }
      }
    },
    {
