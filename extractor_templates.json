{
  "_meta": {
    "version": 1,
    "description": "ETS extraction templates. Each template defines how to detect an email type and what fields to extract. Templates are matched in priority order (highest first). Add new templates here or via the ets_add_extractor agent tool.",
    "agent_instructions": "To add a new extractor template, use the ets_add_extractor tool or append an entry to this file following the schema below. Set a unique id, a descriptive name, detection rules, extraction patterns, and a priority (higher = matched first). Site-specific extractors (e.g. for Amazon, Walmart) should have priority >= 100. Generic type extractors should have priority 50-99."
  },
  "templates": [
    {
      "id": "amazon-shipping",
      "name": "Amazon Shipping Update",
      "priority": 110,
      "type": "shipping",
      "detect": {
        "sender_domain": "amazon.com",
        "subject_regex": "(?i)(shipped|out for delivery|delivered|arriving)"
      },
      "extract": {
        "order_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?i)Order\\s*#?([A-Z0-9\\-]{10,})"
        },
        "status": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)out.?for.?delivery|on its way|with delivery driver": "out_for_delivery",
            "(?i)\\bdelivered\\b|delivery complete|has been delivered": "delivered",
            "(?i)arriving today": "arriving_today",
            "(?i)\\bshipped\\b|has shipped|in transit": "shipped"
          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|arriving|estimated delivery)[:\\s]+([A-Za-z]+ \\d+|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        },
        "carrier": {
          "static": "Amazon"
        },
        "item_hint": {
          "source": "snippet",
          "max_chars": 80
        }
      }
    },
    {
      "id": "ups-shipping",
      "name": "UPS Shipping Update",
      "priority": 110,
      "type": "shipping",
      "detect": {
        "sender_contains": "ups.com",
        "subject_regex": "(?i)(shipped|out for delivery|delivered|arriving|pickup ready)"
      },
      "extract": {
        "tracking_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(1Z[A-Z0-9]{16})"
        },
        "status": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)out.?for.?delivery|on its way": "out_for_delivery",
            "(?i)\\bdelivered\\b|delivery complete": "delivered",
            "(?i)pickup ready|ready for pickup": "pickup_ready",
            "(?i)\\bshipped\\b|in transit|on the way": "shipped"
          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|arriving|delivery date|scheduled delivery)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        },
        "carrier": {
          "static": "UPS"
        }
      }
    },
    {
      "id": "fedex-shipping",
      "name": "FedEx Shipping Update",
      "priority": 110,
      "type": "shipping",
      "detect": {
        "sender_contains": "fedex.com",
        "subject_regex": "(?i)(shipped|out for delivery|delivered|arriving|exception)"
      },
      "extract": {
        "tracking_number": {
          "source": [
            "subject",
            "snippet"
          ],
          "regex": "\\b(\\d{12}|\\d{15}|\\d{20})\\b"
        },
        "status": {
          "source": [
            "subject",
            "snippet"
          ],
          "enum_map": {
            "(?i)out.?for.?delivery|on vehicle": "out_for_delivery",
            "(?i)\\bdelivered\\b|delivery complete": "delivered",
            "(?i)\\bexception\\b|delivery exception": "exception",
            "(?i)\\bshipped\\b|in transit|picked up": "shipped"
          }
        },
        "estimated_delivery": {
          "source": "snippet",
          "regex": "(?i)(?:by|scheduled|delivery date|estimated)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\w+day(?:,\\s*[A-Za-z]+ \\d+)?)"
        },
        "carrier": {
          "static": "FedEx"
        }
      }
    },
    {
      "id": "usps-shipping",
      "name": "USPS Shipping Update",
      "priority": 110,
      "type": "shipping",
      "detect": {
        "sender_contains": "usps.com",
        "subject_regex": "(?i)(shipped|out for delivery|delivered|arriving|in transit|pickup)"
      },
      "extract": {
        "tracking_number": {
          "source": [
