      "name": "Walmart Order Confirmation",
      "priority": 105,
      "type": "order_confirm",
      "detect": {
        "sender_domain": "walmart.com",
        "subject_regex": "(?i)(order (confirmed|received|placed)|thank you for your order|your receipt)"
      },
