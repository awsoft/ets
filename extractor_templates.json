          "source": [
            "subject",
            "snippet"
          ],
          "regex": "(?:due|by|before|pay by)[:\\s]+([A-Za-z]+ \\d+,?\\s*\\d{0,4}|\\d{1,2}/\\d{1,2}/\\d{2,4}|\\d+ days?)"
        },
        "provider": {
          "source": "from_name",
          "max_chars": 40
        }
      }
    }
  ]
