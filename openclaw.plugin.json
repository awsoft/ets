{
  "id": "ets",
  "name": "ETS \u2014 Email Token Saver",
  "description": "Rules-based email pre-filter. Strips noise, extracts structure, and categorizes intent before the LLM sees a single byte.",
  "version": "1.3.3",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rulesPath": {
        "type": "string",
        "description": "Path to email_rules.json"
      },
      "dbPath": {
        "type": "string",
        "description": "Path to SQLite DB"
      },
      "blockThreshold": {
        "type": "number",
        "default": -50
      },
      "allowThreshold": {
        "type": "number",
        "default": 50
      },
      "snippetCap": {
        "type": "number",
        "default": 300
      }
    }
  }
}