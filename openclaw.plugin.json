{
  "id": "ets",
  "name": "ETS — Email Token Saver",
  "description": "Rules-based email pre-filter. Strips noise before LLM sees it.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rulesPath": { "type": "string" },
      "dbPath": { "type": "string" },
      "blockThreshold": { "type": "number" },
      "allowThreshold": { "type": "number" }
    }
  },
  "uiHints": {
    "rulesPath": { "label": "Rules JSON path", "placeholder": "~/.openclaw/extensions/ets/email_rules.json" },
    "blockThreshold": { "label": "Block threshold (default: -50)" },
    "allowThreshold": { "label": "Allow threshold (default: 50)" }
  }
}
