{
  "_meta": {
    "snippet_cap": 300,
    "pipeline": [
      "filter",
      "extract"
    ],
    "version": 1
  },
  "version": 1,
  "rules": [
    {
      "id": "block-legacy-studios",
      "action": "block",
      "weight": 100,
      "match": {
        "sender_contains": "legacystudios"
      },
      "reason": "School photo spam"
    },
    {
      "id": "block-high-yield-investor",
      "action": "block",
      "weight": 100,
      "match": {
        "sender_contains": "highinvestor"
      },
      "reason": "Investment newsletter, not interested"
    },
    {
      "id": "block-weekly-newsletters",
      "action": "block",
      "weight": 80,
      "match": {
        "subject_regex": "(?i)(this week at|weekly newsletter|weekly update|weekly digest|this month at)"
      },
      "reason": "Generic weekly digest emails"
    },
    {
      "id": "block-shipping",
      "action": "block",
      "weight": 90,
      "match": {
        "subject_regex": "(?i)(has shipped|out for delivery|order delivered|your package|delivery update|shipment (update|confirmation))"
      },
      "reason": "Automated shipping notifications"
    },
    {
      "id": "block-promotional",
      "action": "block",
      "weight": 70,
      "match": {
        "subject_regex": "(?i)(\\d+% off|flash sale|limited.time offer|exclusive deal|promo code|use code|shop now|don.t miss|last chance|deal alert|ends tonight|ends sunday)"
      },
      "reason": "Promotional/marketing emails"
    },
    {
      "id": "block-order-confirmations",
      "action": "block",
      "weight": 85,
      "match": {
        "subject_regex": "(?i)(order (confirmed|received|#)|thank you for (your order|shopping))"
      },
      "reason": "Order confirmations - not actionable"
    },
    {
      "id": "block-subscription-renewals",
      "action": "block",
      "weight": 60,
      "match": {
        "subject_regex": "(?i)(subscription (renewal|renew|renewed)|auto.renew|billing (reminder|notice)|invoice (generated|ready))"
      },
      "reason": "Subscription/billing auto-notices - flag only if near expiry via other means"
    },
    {
      "id": "allow-financial-security",
      "action": "allow",
      "weight": 100,
      "match": {
        "subject_regex": "(?i)(fraud alert|unusual (activity|sign.in)|account (locked|suspended|compromised|disabled)|security alert|payment (failed|declined)|wire transfer|verify your)"
      },
      "reason": "Financial/security alerts - always important"
    },
    {
      "id": "allow-job-search",
      "action": "allow",
      "weight": 95,
      "match": {
        "subject_regex": "(?i)(job offer|offer letter|interview (invitation|request|scheduled)|application (received|update|status)|recruiter|we.d like to (speak|connect|discuss))"
      },
      "reason": "Active job search - flag all"
    },
    {
      "id": "allow-playmetrics",
      "action": "allow",
      "weight": 85,
      "match": {
        "sender_contains": "playmetrics"
      },
      "reason": "Soccer schedule platform"
    }
  ]
}
