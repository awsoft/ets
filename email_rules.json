{
  "_meta": {
    "snippet_cap": 300,
    "pipeline": ["filter", "extract"],
    "version": 1
  },
  "rules": [
    {
      "id": "block-weekly-newsletters",
      "action": "block",
      "weight": 80,
      "match": { "subject_regex": "(?i)(this week at|weekly newsletter|weekly update|weekly digest|this month at|monthly newsletter|monthly update)" },
      "reason": "Generic weekly/monthly digest emails"
    },
    {
      "id": "block-shipping-notifications",
      "action": "block",
      "weight": 90,
      "match": { "subject_regex": "(?i)(has shipped|out for delivery|order delivered|your package|delivery update|shipment (update|confirmation)|delivered today|arriving today|arriving tomorrow)" },
      "reason": "Automated shipping/delivery notifications"
    },
    {
      "id": "block-promotional",
      "action": "block",
      "weight": 70,
      "match": { "subject_regex": "(?i)(\\d+% off|flash sale|limited.time offer|exclusive deal|promo code|use code|shop now|don.t miss|last chance|deal alert|ends tonight|ends sunday|save up to|buy now)" },
      "reason": "Promotional and marketing emails"
    },
    {
      "id": "block-order-confirmations",
      "action": "block",
      "weight": 85,
      "match": { "subject_regex": "(?i)(order (confirmed|received|#\\d)|thank you for (your order|shopping with us))" },
      "reason": "Order confirmation receipts - not actionable"
    },
    {
      "id": "block-social-digests",
      "action": "block",
      "weight": 75,
      "match": { "subject_regex": "(?i)(people you may know|suggested for you|trending (now|today)|top (posts|stories|updates)|see what.s new|activity digest|notification digest)" },
      "reason": "Social platform digest emails"
    },
    {
      "id": "allow-financial-security",
      "action": "allow",
      "weight": 100,
      "match": { "subject_regex": "(?i)(fraud alert|unusual (activity|sign.in)|account (locked|suspended|compromised|disabled)|security alert|payment (failed|declined)|wire transfer|verify your (identity|account)|suspicious)" },
      "reason": "Financial and security alerts - always important"
    },
    {
      "id": "allow-job-search",
      "action": "allow",
      "weight": 95,
      "match": { "subject_regex": "(?i)(offer letter|interview (invitation|request|scheduled|confirmed)|we.d like to (speak|connect|discuss|interview)|application (status update|decision|moved forward))" },
      "reason": "Job search milestone emails - always flag"
    }
  ]
}
